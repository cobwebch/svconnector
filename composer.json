{
  "name": "cobweb/svconnector",
  "type": "typo3-cms-extension",
  "description": "Connector Services – This family of services is used to connect to external data sources and fetch data from them. This is just a base class which cannot be used by itself. Implementations are done for specific subtypes.",
  "license": [
    "GPL-2.0-or-later"
  ],
  "authors": [
    {
      "name": "Francois Suter",
      "role": "Developer",
      "homepage": "https://www.ideative.ch/en/"
    }
  ],
  "autoload": {
    "psr-4": {
      "Cobweb\\Svconnector\\": "Classes/"
    }
  },
  "require": {
    "php": "^8.2 || ^8.3 || ^8.4 || ^8.5",
    "ext-simplexml": "*",
    "typo3/cms-core": "^13.4 || ^14.3"
  },
  "require-dev": {
    "ergebnis/composer-normalize": "^2.51",
    "friendsofphp/php-cs-fixer": "^3.95",
    "typo3/coding-standards": "*",
    "typo3/testing-framework": "^9.5",
    "phpstan/phpstan": "^2.1"
  },
  "replace": {
    "typo3-ter/svconnector": "self.version"
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "svconnector",
      "web-dir": ".Build/web",
      "version": "7.0.0",
      "Package": {
        "providesPackages": {
        }
      }
    }
  },
  "config": {
    "allow-plugins": {
      "typo3/cms-composer-installers": true,
      "typo3/class-alias-loader": true,
      "ergebnis/composer-normalize": true
    },
    "bin-dir": ".Build/bin",
    "sort-packages": true,
    "vendor-dir": ".Build/vendor"
  }
}
